{
  "mcpServers": {
    "Context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "disabled": false,
      "alwaysAllow": [
        "resolve-library-id",
        "get-library-docs"
      ]
    },
    "gemini-image-generation-mcp": {
      "command": "node",
      "args": [
        "~/work/mcp/gemini-image-generation-mcp/dist/index.js"
      ],
      "disabled": false,
      "alwaysAllow": [],
      "timeout": 300
    }
  }
}
